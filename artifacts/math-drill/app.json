{
  "expo": {
    "name": "Math Speed Drill",
    "slug": "math-drill",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "math-drill",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a5f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.suraj220.mathspeeddrill",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Not used",
        "NSLocationWhenInUseUsageDescription": "Not used"
      }
    },
    "android": {
      "package": "com.suraj220.mathspeeddrill",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1e3a5f"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
